{
  "name": "daystep",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/setup-dev-ip.js && cross-env NODE_ENV=development next dev",
    "dev:direct": "cross-env NODE_ENV=development next dev",
    "dev:clean": "rm -rf .next/cache && npm run dev",
    "dev:stable": "rm -rf .next && npm run dev",
    "dev:safe": "rm -rf .next node_modules/.cache && npm run dev",
    "build": "cross-env NODE_ENV=production BUILD_TARGET=web next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern=__tests__/unit",
    "test:integration": "jest --testPathPattern=__tests__/integration",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:all": "npm run test:coverage && npm run test:e2e",
    "build:mobile": "cross-env NODE_ENV=development BUILD_TARGET=mobile next build && npm run mobile:sync",
    "build:mobile:prod": "cross-env NODE_ENV=production BUILD_TARGET=mobile next build && npm run mobile:sync",
    "dev:mobile": "node scripts/mobile-build-with-hotreload.js",
    "build:mobile:no-pods": "node scripts/setup-dev-ip.js && node scripts/build-mobile-routes.js backup && node scripts/build-mobile-routes.js mobile && cross-env NODE_ENV=development BUILD_TARGET=mobile npx next build && npm run mobile:copy && node scripts/build-mobile-routes.js restore",
    "build:web": "cross-env NODE_ENV=production BUILD_TARGET=web next build",
    "dev:web": "node scripts/setup-dev-ip.js && pkill -f \"next dev\" || true && cross-env NODE_ENV=development BUILD_TARGET=web npm run dev",
    "preview:web": "node scripts/setup-dev-ip.js && cross-env NODE_ENV=production PREVIEW_MODE=true BUILD_TARGET=web NEXT_PUBLIC_SITE_URL=http://localhost:3000 npm run build && npm start",
    "mobile:copy": "cd mobile && npx cap copy",
    "mobile:build": "npm run build:mobile",
    "mobile:sync": "cd mobile && npx cap sync",
    "mobile:ios": "cd mobile && npx cap open ios",
    "mobile:android": "cd mobile && npx cap open android",
    "mobile:run:ios": "cd mobile && npx cap run ios",
    "mobile:run:android": "cd mobile && npx cap run android",
    "mobile:dev:ios": "npm run mobile:build && npm run mobile:run:ios",
    "logs:filter": "./scripts/xcode-log-filter.sh",
    "logs:clean": "xcrun simctl spawn booted log erase",
    "mobile:dev:android": "npm run mobile:build && npm run mobile:run:android",
    "mobile:doctor": "cd mobile && npx cap doctor",
    "mobile:clean": "cd mobile && npx cap clean && npm run mobile:sync",
    "mobile:update": "cd mobile && npx cap update",
    "mobile:serve": "npm run build:mobile && cd mobile && npx cap serve",
    "prebuild:mobile": "node scripts/validate-build.js pre-build mobile && npm run lint && npm run test:unit",
    "postbuild:mobile": "node scripts/validate-build.js post-build mobile && npm run mobile:doctor",
    "prebuild:web": "node scripts/validate-build.js pre-build web",
    "postbuild:web": "node scripts/validate-build.js post-build web",
    "validate:build": "node scripts/validate-build.js build-with-validation",
    "validate:env": "node scripts/validate-build.js pre-build",
    "setup:ip": "node scripts/setup-dev-ip.js",
    "analyze:bundle": "ANALYZE=true npm run build:web",
    "analyze:mobile": "node scripts/validate-build.js post-build mobile",
    "debug:build": "DEBUG=* npm run build",
    "debug:mobile": "DEBUG=capacitor* npm run mobile:build",
    "migrate:todos": "tsx scripts/migrate-todos-schema.ts",
    "migrate:todos:dry-run": "DRY_RUN=true tsx scripts/migrate-todos-schema.ts",
    "migrate:todos:drop-old": "DROP_OLD_COLUMN=true tsx scripts/migrate-todos-schema.ts"
  },
  "dependencies": {
    "@capacitor-community/contacts": "^7.0.0",
    "@capacitor/android": "^7.4.2",
    "@capacitor/app": "^7.0.1",
    "@capacitor/browser": "^7.0.1",
    "@capacitor/cli": "^7.4.2",
    "@capacitor/core": "^7.4.2",
    "@capacitor/http": "^0.0.2",
    "@capacitor/ios": "^7.4.2",
    "@capacitor/keyboard": "^7.0.3",
    "@capacitor/local-notifications": "^7.0.2",
    "@capacitor/preferences": "^7.0.1",
    "@capacitor/push-notifications": "^7.0.1",
    "@capacitor/status-bar": "^7.0.1",
    "@capgo/capacitor-social-login": "^7.8.3",
    "@codemirror/commands": "^6.8.1",
    "@codemirror/lang-markdown": "^6.3.4",
    "@codemirror/state": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.38.2",
    "@daystep/contact-groups": "file:plugins/contact-groups",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@heroicons/react": "^2.2.0",
    "@hookform/resolvers": "^5.2.0",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@react-spring/web": "^10.0.1",
    "@supabase/ssr": "~0.6.1",
    "@supabase/supabase-js": "~2.52.0",
    "@types/react-datepicker": "^6.2.0",
    "@types/react-window": "^1.8.8",
    "@uiw/react-codemirror": "^4.25.1",
    "@uiw/react-md-editor": "^4.0.8",
    "@use-gesture/react": "^10.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dexie": "^4.0.11",
    "framer-motion": "^12.23.24",
    "google-auth-library": "^10.3.1",
    "googleapis": "^160.0.0",
    "gsap": "^3.13.0",
    "immer": "^10.1.1",
    "lucide-react": "^0.525.0",
    "motion": "^12.23.12",
    "next": "15.1.5",
    "next-pwa": "^5.6.0",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-confetti-explosion": "^3.0.3",
    "react-datepicker": "^8.7.0",
    "react-day-picker": "^8.10.1",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.61.1",
    "react-modal-sheet": "^4.4.0",
    "react-textarea-autosize": "^8.5.9",
    "react-window": "^1.8.11",
    "rrule": "^2.8.1",
    "slate": "^0.118.1",
    "slate-dom": "^0.118.1",
    "slate-react": "^0.117.4",
    "sonner": "^2.0.6",
    "tailwind-merge": "^3.3.1",
    "web-vitals": "^5.0.3",
    "workbox-webpack-plugin": "^7.3.0",
    "zod": "^4.0.10",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^15.4.4",
    "@playwright/test": "^1.54.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.0",
    "cross-env": "^10.1.0",
    "daisyui": "^5.1.28",
    "dotenv": "^17.2.1",
    "env-cmd": "^11.0.0",
    "eslint": "^8",
    "eslint-config-next": "15.1.5",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "msw": "^2.10.4",
    "postcss": "^8",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.4.0",
    "tsx": "^4.20.4",
    "typescript": "^5"
  }
}
