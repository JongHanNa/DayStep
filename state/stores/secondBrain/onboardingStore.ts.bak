/**
 * Onboarding Store - 온보딩 진행 상태 관리
 * 5단계 온보딩 프로세스 추적
 */

import { createStore } from '@/state/utils/storeUtils';
import type { OnboardingProgress, OnboardingStep } from '@/types/second-brain';
import { saveMockDataToLocalStorage } from '@/lib/mockData/secondBrain';

interface OnboardingStoreState {
  progress: OnboardingProgress | null;
  currentStep: OnboardingStep;
  loading: boolean;
  error: string | null;

  // Actions
  fetchProgress: () => Promise<void>;
  startOnboarding: () => Promise<OnboardingProgress>;
  completeStep: (step: OnboardingStep) => Promise<OnboardingProgress>;
  skipOnboarding: () => Promise<OnboardingProgress>;
  resetOnboarding: () => Promise<OnboardingProgress>;
  setCurrentStep: (step: OnboardingStep) => void;
}

export const useOnboardingStore = createStore<OnboardingStoreState>(
  (set, get) => ({
    progress: null,
    currentStep: 1,
    loading: false,
    error: null,

    fetchProgress: async () => {
      try {
        set({ loading: true, error: null });

        // LocalStorage에서 온보딩 진행 상태 로드
        const storedProgress = localStorage.getItem('daystep-onboarding');

        if (storedProgress) {
          const progress = JSON.parse(storedProgress) as OnboardingProgress;

          // 현재 단계 계산
          let currentStep: OnboardingStep = 1;
          if (!progress.step_1_areas) currentStep = 1;
          else if (!progress.step_2_resources) currentStep = 2;
          else if (!progress.step_3_goals) currentStep = 3;
          else if (!progress.step_4_projects) currentStep = 4;
          else if (!progress.step_5_todos) currentStep = 5;

          set({ progress, currentStep, loading: false });
        } else {
          set({ progress: null, currentStep: 1, loading: false });
        }
      } catch (error) {
        set({
          error: error instanceof Error ? error.message : '온보딩 진행 상태를 불러오는데 실패했습니다.',
          loading: false,
        });
      }
    },

    startOnboarding: async () => {
      try {
        set({ loading: true, error: null });

        const newProgress: OnboardingProgress = {
          id: `onboarding-${Date.now()}`,
          user_id: 'mock-user-123',
          step_1_areas: false,
          step_2_resources: false,
          step_3_goals: false,
          step_4_projects: false,
          step_5_todos: false,
          completed: false,
          created_at: new Date().toISOString(),
          updated_at: new Date().toISOString(),
        };

        set({ progress: newProgress, currentStep: 1, loading: false });

        // LocalStorage 저장
        localStorage.setItem('daystep-onboarding', JSON.stringify(newProgress));
        saveMockDataToLocalStorage();

        return newProgress;
      } catch (error) {
        set({
          error: error instanceof Error ? error.message : '온보딩 시작에 실패했습니다.',
          loading: false,
        });
        throw error;
      }
    },

    completeStep: async (step: OnboardingStep) => {
      try {
        set({ loading: true, error: null });

        const currentProgress = get().progress;
        if (!currentProgress) {
          throw new Error('온보딩이 시작되지 않았습니다.');
        }

        const updatedProgress: OnboardingProgress = {
          ...currentProgress,
          [`step_${step}_${
            step === 1 ? 'areas' :
            step === 2 ? 'resources' :
            step === 3 ? 'goals' :
            step === 4 ? 'projects' :
            'todos'
          }`]: true,
          updated_at: new Date().toISOString(),
        };

        // 모든 단계 완료 확인
        const allStepsCompleted =
          updatedProgress.step_1_areas &&
          updatedProgress.step_2_resources &&
          updatedProgress.step_3_goals &&
          updatedProgress.step_4_projects &&
          updatedProgress.step_5_todos;

        if (allStepsCompleted) {
          updatedProgress.completed = true;
          updatedProgress.completed_at = new Date().toISOString();
        }

        // 다음 단계 계산
        const nextStep = Math.min(step + 1, 5) as OnboardingStep;

        set({
          progress: updatedProgress,
          currentStep: allStepsCompleted ? 5 : nextStep,
          loading: false
        });

        // LocalStorage 저장
        localStorage.setItem('daystep-onboarding', JSON.stringify(updatedProgress));
        saveMockDataToLocalStorage();

        return updatedProgress;
      } catch (error) {
        set({
          error: error instanceof Error ? error.message : '단계 완료 처리에 실패했습니다.',
          loading: false,
        });
        throw error;
      }
    },

    skipOnboarding: async () => {
      try {
        set({ loading: true, error: null });

        const currentProgress = get().progress;
        if (!currentProgress) {
          throw new Error('온보딩이 시작되지 않았습니다.');
        }

        const skippedProgress: OnboardingProgress = {
          ...currentProgress,
          step_1_areas: true,
          step_2_resources: true,
          step_3_goals: true,
          step_4_projects: true,
          step_5_todos: true,
          completed: true,
          completed_at: new Date().toISOString(),
          updated_at: new Date().toISOString(),
        };

        set({ progress: skippedProgress, currentStep: 5, loading: false });

        // LocalStorage 저장
        localStorage.setItem('daystep-onboarding', JSON.stringify(skippedProgress));
        saveMockDataToLocalStorage();

        return skippedProgress;
      } catch (error) {
        set({
          error: error instanceof Error ? error.message : '온보딩 건너뛰기에 실패했습니다.',
          loading: false,
        });
        throw error;
      }
    },

    resetOnboarding: async () => {
      try {
        set({ loading: true, error: null });

        // 온보딩 상태 초기화
        localStorage.removeItem('daystep-onboarding');
        set({ progress: null, currentStep: 1, loading: false });

        // LocalStorage 저장
        saveMockDataToLocalStorage();

        return {
          id: '',
          user_id: '',
          step_1_areas: false,
          step_2_resources: false,
          step_3_goals: false,
          step_4_projects: false,
          step_5_todos: false,
          completed: false,
          created_at: '',
          updated_at: '',
        };
      } catch (error) {
        set({
          error: error instanceof Error ? error.message : '온보딩 초기화에 실패했습니다.',
          loading: false,
        });
        throw error;
      }
    },

    setCurrentStep: (step: OnboardingStep) => {
      set({ currentStep: step });
    },
  }),
  {
    name: 'onboarding-store',
    persist: {
      name: 'daystep-onboarding-state',
    },
  }
);
