require File.join(File.dirname(`node --print "require.resolve('expo/package.json')"`), "scripts/autolinking")
# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'DayStepRN' do
  use_expo_modules!

  if ENV['EXPO_USE_COMMUNITY_AUTOLINKING'] == '1'
    config_command = ['node', '-e', "process.argv=['', '', 'config'];require('@react-native-community/cli').run()"];
  else
    config_command = [
      'node',
      '--no-warnings',
      '--eval',
      'require(require.resolve(\'expo-modules-autolinking\', { paths: [require.resolve(\'expo/package.json\')] }))(process.argv.slice(1))',
      'react-native-config',
      '--json',
      '--platform',
      'ios'
    ]
  end

  config = use_native_modules!(config_command)

  pod 'MMKV'  # AppDelegate에서 import MMKV 사용 (UI 테스트 세션 주입)

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # react-native-config ENVFILE: /tmp/envfile 의존 제거 → xcconfig build setting으로 대체
    # pod install 이후에도 ENVFILE 설정이 유지되도록 영속성 확보
    installer.pods_project.targets.each do |target|
      if target.name == 'react-native-config'
        target.build_configurations.each do |config|
          if config.name == 'Debug'
            config.build_settings['ENVFILE'] = '.env'
          elsif config.name == 'Release'
            config.build_settings['ENVFILE'] = '.env.production'
          end
        end

        # v17: Run Script 완료 후 RNCConfig.m 재컴파일 강제
        # alwaysOutOfDate=1로 Run Script가 항상 실행되지만, RNCConfig.m 컴파일은
        # planning time에 "up-to-date"로 결정됨. outputPaths에 RNCConfig.m 추가 +
        # touch로 타임스탬프 갱신 → Run Script 완료 후 XCBuild가 재컴파일 평가
        target.build_phases.each do |phase|
          next unless phase.is_a?(Xcodeproj::Project::Object::PBXShellScriptBuildPhase)
          next unless phase.shell_script.include?('BuildDotenvConfig.rb')

          rnc_path = '${PODS_TARGET_SRCROOT}/ios/ReactNativeConfig/RNCConfig.m'

          unless phase.shell_script.include?('touch "${PODS_TARGET_SRCROOT}/ios/ReactNativeConfig/RNCConfig.m"')
            phase.shell_script += "\ntouch \"${PODS_TARGET_SRCROOT}/ios/ReactNativeConfig/RNCConfig.m\""
          end

          phase.output_paths << rnc_path unless phase.output_paths.include?(rnc_path)
        end
      end
    end

    # Fix: RCTSwiftUI modulemap not found during Xcode Clang dependency scanning.
    # The scanner runs BEFORE build phases, so it can't find the modulemap
    # at ${PODS_CONFIGURATION_BUILD_DIR}/RCTSwiftUI/ (only exists after building).
    # Rewrite the path in generated xcconfig files to the source location.
    xcconfig_dir = "#{installer.sandbox.root}/Target Support Files/Pods-DayStepRN"
    Dir.glob("#{xcconfig_dir}/*.xcconfig").each do |xcconfig_path|
      content = File.read(xcconfig_path)
      if content.include?('${PODS_CONFIGURATION_BUILD_DIR}/RCTSwiftUI/RCTSwiftUI.modulemap')
        content.gsub!(
          '${PODS_CONFIGURATION_BUILD_DIR}/RCTSwiftUI/RCTSwiftUI.modulemap',
          '${PODS_ROOT}/Target Support Files/RCTSwiftUI/RCTSwiftUI.modulemap'
        )
        File.write(xcconfig_path, content)
      end
    end
  end
end
