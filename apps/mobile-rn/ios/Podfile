# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'DayStepRN' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Fix: RCTSwiftUI modulemap not found during Xcode Clang dependency scanning.
    # The scanner runs BEFORE build phases, so it can't find the modulemap
    # at ${PODS_CONFIGURATION_BUILD_DIR}/RCTSwiftUI/ (only exists after building).
    # Rewrite the path in generated xcconfig files to the source location.
    xcconfig_dir = "#{installer.sandbox.root}/Target Support Files/Pods-DayStepRN"
    Dir.glob("#{xcconfig_dir}/*.xcconfig").each do |xcconfig_path|
      content = File.read(xcconfig_path)
      if content.include?('${PODS_CONFIGURATION_BUILD_DIR}/RCTSwiftUI/RCTSwiftUI.modulemap')
        content.gsub!(
          '${PODS_CONFIGURATION_BUILD_DIR}/RCTSwiftUI/RCTSwiftUI.modulemap',
          '${PODS_ROOT}/Target Support Files/RCTSwiftUI/RCTSwiftUI.modulemap'
        )
        File.write(xcconfig_path, content)
      end
    end
  end
end
