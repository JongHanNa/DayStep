{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "types": [
      "jest"
    ],
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@daystep/shared-core": [
        "../../packages/shared-core/src"
      ],
      "@daystep/shared-core/*": [
        "../../packages/shared-core/src/*"
      ],
      "@daystep/shared-utils": [
        "../../packages/shared-utils/src"
      ],
      "@daystep/shared-utils/*": [
        "../../packages/shared-utils/src/*"
      ],
      "@/*": [
        "src/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "nativewind-env.d.ts"
  ],
  "exclude": [
    "**/node_modules",
    "**/Pods"
  ]
}