    "concurrently": "^9.1.0",
    "cross-env": "^10.1.0",
    "daisyui": "^5.1.28",
    "dotenv": "^17.2.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.0.0",
    "env-cmd": "^11.0.0",
    "eslint": "^8",
    "eslint-config-next": "15.1.5",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
