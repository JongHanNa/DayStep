{
  "name": "@daystep/web",
  "version": "0.1.0",
  "private": true,
  "main": "../desktop/dist/main.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development next dev",
    "dev:direct": "cross-env NODE_ENV=development next dev",
    "dev:clean": "rm -rf .next/cache && npm run dev",
    "dev:stable": "rm -rf .next && npm run dev",
    "dev:safe": "rm -rf .next node_modules/.cache && npm run dev",
    "build": "cross-env NODE_ENV=production BUILD_TARGET=web next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern=__tests__/unit",
    "test:integration": "jest --testPathPattern=__tests__/integration",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:all": "npm run test:coverage && npm run test:e2e",
    "build:web": "cross-env NODE_ENV=production BUILD_TARGET=web next build",
    "dev:web": "pkill -f \"next dev\" || true && cross-env NODE_ENV=development BUILD_TARGET=web npm run dev",
    "preview:web": "cross-env NODE_ENV=production PREVIEW_MODE=true BUILD_TARGET=web NEXT_PUBLIC_SITE_URL=http://localhost:3000 npm run build && npm start",
    "logs:filter": "./scripts/xcode-log-filter.sh",
    "logs:clean": "xcrun simctl spawn booted log erase",
    "analyze:bundle": "ANALYZE=true npm run build:web",
    "debug:build": "DEBUG=* npm run build",
    "migrate:todos": "tsx scripts/migrate-todos-schema.ts",
    "migrate:todos:dry-run": "DRY_RUN=true tsx scripts/migrate-todos-schema.ts",
    "migrate:todos:drop-old": "DROP_OLD_COLUMN=true tsx scripts/migrate-todos-schema.ts",
    "build:electron": "node scripts/build-electron-dev.js",
    "build:electron:prod": "node scripts/build-electron-prod.js",
    "dev:electron": "node scripts/build-electron-dev.js",
    "package:electron": "electron-builder --mac --win",
    "package:electron:mac": "electron-builder --mac",
    "package:electron:win": "electron-builder --win"
  },
