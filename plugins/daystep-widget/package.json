{
  "name": "daystep-widget",
  "version": "1.0.0",
  "description": "DayStep iOS Widget plugin for Capacitor",
  "main": "dist/plugin.cjs.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "unpkg": "dist/plugin.js",
  "scripts": {
    "build": "npm run clean && npm run docgen && tsc && rollup -c rollup.config.js",
    "clean": "rimraf ./dist",
    "docgen": "docgen --api DayStepWidgetPlugin --output-readme README.md --output-json dist/docs.json",
    "eslint": "eslint . --ext ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "capacitor",
    "plugin",
    "native",
    "ios",
    "widget"
  ],
  "capacitor": {
    "ios": {
      "src": "ios"
    }
  },
  "devDependencies": {
    "@capacitor/core": "^7.4.2",
    "@capacitor/docgen": "^0.2.2",
    "@capacitor/ios": "^7.4.2",
    "@ionic/eslint-config": "^0.3.0",
    "@ionic/prettier-config": "^4.0.0",
    "eslint": "^7.11.0",
    "prettier": "~2.3.0",
    "prettier-plugin-java": "~1.0.2",
    "rimraf": "^3.0.2",
    "rollup": "^2.29.0",
    "typescript": "~4.1.5"
  },
  "peerDependencies": {
    "@capacitor/core": "^7.0.0"
  },
  "prettier": "@ionic/prettier-config",
  "eslintConfig": {
    "extends": "@ionic/eslint-config/recommended"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/daystep/daystep-widget.git"
  },
  "bugs": {
    "url": "https://github.com/daystep/daystep-widget/issues"
  },
  "homepage": "https://github.com/daystep/daystep-widget#readme"
}