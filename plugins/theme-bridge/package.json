{
  "name": "@daystep/theme-bridge",
  "version": "1.0.0",
  "description": "Capacitor plugin for iOS WebView background color synchronization (dark mode overscroll)",
  "main": "dist/plugin.cjs.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "unpkg": "dist/plugin.js",
  "files": [
    "dist/",
    "ios/Plugin/"
  ],
  "author": "DayStep Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JongHanNa/DayStep.git"
  },
  "keywords": [
    "capacitor",
    "plugin",
    "native",
    "theme",
    "dark-mode",
    "ios"
  ],
  "scripts": {
    "build": "npm run clean && tsc && rollup -c rollup.config.js",
    "clean": "rimraf ./dist",
    "watch": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@capacitor/core": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "rimraf": "^3.0.0",
    "rollup": "^2.32.0",
    "typescript": "~5.0.0"
  },
  "peerDependencies": {
    "@capacitor/core": "^7.0.0"
  },
  "capacitor": {
    "ios": {
      "src": "ios"
    }
  }
}
